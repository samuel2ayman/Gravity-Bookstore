  <MdxScripts>
    <MdxScript dwd:design-time-name="120ecfbf-85d3-483d-a415-26233471f781">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;   
CREATE MEMBER CURRENTCUBE.[Measures].Total_Customers
 AS -- This filters out the Unknown member and any Nulls
COUNT(
    FILTER(
        [Customer].[Customer ID BK].Children,
        [Customer].[Customer ID BK].CurrentMember.Name &lt;&gt; "Unknown" 
        AND NOT IsEmpty([Customer].[Customer ID BK].CurrentMember)
    )
), 
FORMAT_STRING = "Standard", 
VISIBLE = 1  ;  
CREATE MEMBER CURRENTCUBE.[Measures].AVG_spent_per_customer
 AS [Measures].[Price] /[Measures].[Total_Customers], 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].Delivery_Rate
 AS [Measures].[Delivered_Orders] / [Measures].[Order Id], 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].Cancellation_Rate
 AS [Measures].[Cancelled_Orders] / [Measures].[Order Id], 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].Total_Authors
 AS COUNT(
    FILTER(
        [Author].[Author Key].Children,
        [Author].[Author Key].CurrentMember.Name &lt;&gt; "Unknown" 
        AND NOT IsEmpty([Author].[Author Key].CurrentMember.Member_Value)
    )
), 
VISIBLE = 1  ;  
CREATE MEMBER CURRENTCUBE.[Measures].Total_Books
 AS count([Book].[Book Key].MEMBERS), 
VISIBLE = 1  ;  
CREATE MEMBER CURRENTCUBE.[Measures].Cancelled_Orders
 AS (

[Measures].[Order Id],

[Status].[Status Value].&amp;[Cancelled]

), 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].AVG_order_price
 AS [Measures].[Price] / [Measures].[Order Id], 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].Delivered_Orders
 AS (
    [Measures].[Order Id],
    [Status].[Status Value].&amp;[Delivered]
), 
VISIBLE = 1; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>